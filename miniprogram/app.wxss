/* app.wxss - 全局样式 */

/* 金融配色系统 */
page {
  height: 100%;
  /* 专业金融蓝背景 */
  background: linear-gradient(180deg, #0052D9 0%, #1677FF 100%);
  --finance-primary: #1677FF; /* 核心科技蓝 */
  --finance-primary-dark: #0052D9; /* 深蓝 */
  --finance-primary-light: #4096FF; /* 浅蓝 */
  
  /* 涨跌配色 - 中国标准：红涨绿跌 */
  --finance-rise: #D32F2F; /* 朱红 */
  --finance-rise-light: #EF5350; /* 浅朱红 */
  --finance-fall: #388E3C; /* 墨绿 */
  --finance-fall-light: #66BB6A; /* 浅墨绿 */
  
  /* 预警色 */
  --finance-warning: #FFA726; /* 琥珀色 */
  --finance-warning-bg: #FFF3E0; /* 警告背景 */
  
  /* 背景与卡片 */
  --finance-bg: #F5F5F5; /* 浅灰背景 */
  --finance-card-bg: #FFFFFF; /* 卡片纯白 */
  
  /* 文字颜色 */
  --finance-text-primary: #1A1A1A; /* 主要文字 */
  --finance-text-secondary: #666666; /* 次要文字 */
  --finance-text-tertiary: #999999; /* 辅助文字 */
  --finance-text-disabled: #CCCCCC; /* 禁用文字 */
  
  /* 分割线 */
  --finance-border: #E0E0E0;
  --finance-border-light: #F0F0F0;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 玻璃拟态效果 - 金融版 */
.glass {
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx 0 rgba(0, 82, 217, 0.15);
}

/* 卡片样式 - 专业金融卡片 */
.card {
  background: var(--finance-card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid var(--finance-border-light);
}

/* 按钮样式 - 金融蓝 */
.btn {
  background: linear-gradient(135deg, #1677FF 0%, #0052D9 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.3);
}

.btn-disabled {
  opacity: 0.5;
  box-shadow: none;
}

/* 输入框样式 */
.input {
  background: #fff;
  border: 2rpx solid var(--finance-border);
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--finance-text-primary);
}

.input:focus {
  border-color: var(--finance-primary);
}

/* 文字颜色 */
.text-primary {
  color: var(--finance-primary);
}

.text-success {
  color: var(--finance-rise);
}

.text-danger {
  color: var(--finance-fall);
}

.text-muted {
  color: var(--finance-text-tertiary);
}

.text-white {
  color: #ffffff;
}

/* 涨跌颜色 - 中国标准：红涨绿跌 */
.rise {
  color: var(--finance-rise);
}

.fall {
  color: var(--finance-fall);
}

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-center {
  justify-content: center;
  align-items: center;
}

.flex-between {
  justify-content: space-between;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* 间距 */
.mt-10 {
  margin-top: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.ml-10 {
  margin-left: 10rpx;
}

.mr-10 {
  margin-right: 10rpx;
}

.p-20 {
  padding: 20rpx;
}

/* 字体大小 */
.fs-24 {
  font-size: 24rpx;
}

.fs-28 {
  font-size: 28rpx;
}

.fs-32 {
  font-size: 32rpx;
}

.fs-36 {
  font-size: 36rpx;
}

.fs-40 {
  font-size: 40rpx;
}

/* 字体粗细 */
.fw-bold {
  font-weight: bold;
}

.fw-medium {
  font-weight: 500;
}

/* 金融数字字体 - 使用等宽数字 */
.finance-number {
  font-family: 'DIN Alternate', 'Roboto', 'Helvetica Neue', -apple-system, sans-serif;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.5rpx;
}

/* 文字对齐 */
.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

/* 预警标签 */
.warning-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: var(--finance-warning-bg);
  color: var(--finance-warning);
  font-size: 22rpx;
  border-radius: 6rpx;
  border: 1rpx solid var(--finance-warning);
}
