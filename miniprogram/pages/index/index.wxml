<!-- pages/index/index.wxml -->
<view class="index-container">
  <!-- 头部搜索区域 -->
  <view class="glass search-section">
    <view class="search-box">
      <input 
        class="search-input" 
        placeholder="输入小鸡编号或名称搜索" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="handleSearch"
      />
      <view class="search-btn" bindtap="handleSearch">
        <view class="icon-search"></view>
      </view>
    </view>

    <!-- 搜索结果 -->
    <view wx:if="{{searchResults.length > 0}}" class="search-results">
      <scroll-view scroll-y class="results-list">
        <view 
          wx:for="{{searchResults}}" 
          wx:key="code" 
          class="result-item"
          bindtap="handleAddFund"
          data-fund="{{item}}"
        >
          <view class="result-info">
            <text class="result-code">{{item.code}}</text>
            <text class="result-name">{{item.name}}</text>
          </view>
          <text class="add-icon">+</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- Tab切换 -->
  <view class="glass tab-section">
    <view 
      class="tab-item {{currentTab === 0 ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="0"
    >
      <text>全部({{allCount}})</text>
    </view>
    <view 
      class="tab-item {{currentTab === 1 ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="1"
    >
      <text>收藏({{favoriteCount}})</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <view class="action-left">
      <view class="refresh-btn" bindtap="handleRefresh">
        <view class="icon-refresh {{refreshing ? 'rotating' : ''}}"></view>
        <text class="btn-text">刷新</text>
      </view>
    </view>
    <view class="action-right">
      <view class="settings-btn" bindtap="showSettingsModal">
        <view class="icon-settings"></view>
        <text class="btn-text">设置</text>
      </view>
    </view>
  </view>

  <!-- 小鸡列表 -->
  <scroll-view 
    scroll-y 
    class="fund-list"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="handleRefresh"
  >
    <view wx:if="{{displayFunds.length === 0}}" class="empty-state">
      <view class="empty-icon"></view>
      <text class="empty-text">{{currentTab === 0 ? '还没有添加小鸡' : '还没有收藏小鸡'}}</text>
      <text class="empty-hint">在上方搜索栏添加小鸡</text>
    </view>

    <view 
      wx:for="{{displayFunds}}" 
      wx:key="code" 
      class="glass fund-card"
      bindtap="showFundDetail"
      data-fund="{{item}}"
    >
      <!-- 小鸡头部 -->
      <view class="fund-header">
        <view class="fund-info">
          <text class="fund-name">{{item.name}}</text>
          <text class="fund-code">{{item.code}}</text>
        </view>
        <view class="fund-actions">
          <view 
            class="action-icon favorite-icon {{item.favorite ? 'active' : ''}}"
            catchtap="toggleFavorite"
            data-code="{{item.code}}"
          >
            <text>{{item.favorite ? '★' : '☆'}}</text>
          </view>
          <view 
            class="action-icon delete-icon"
            catchtap="confirmDelete"
            data-code="{{item.code}}"
          >
            <text>×</text>
          </view>
        </view>
      </view>

      <!-- 体重信息 -->
      <view class="fund-values">
        <view class="value-item">
          <text class="value-label">体重</text>
          <text class="value-number">{{item.dwjz || '--'}}</text>
          <text class="value-date">{{item.jzrq || '--'}}</text>
        </view>
        <view class="value-divider"></view>
        <view class="value-item">
          <text class="value-label">{{item.displayLabel || '预估体重'}}</text>
          <view class="estimate-row">
            <text class="value-number {{item.displayGszzl > 0 ? 'rise' : item.displayGszzl < 0 ? 'fall' : ''}}">{{item.displayGsz || '--'}}</text>
            <text class="value-change-inline {{item.displayGszzl > 0 ? 'rise' : item.displayGszzl < 0 ? 'fall' : ''}}">({{item.displayGszzl > 0 ? '+' : ''}}{{item.displayGszzl}}%)</text>
          </view>
          <text class="value-date">{{item.displayTime || '--'}}</text>
        </view>
      </view>

      <!-- 分时图 -->
      <view wx:if="{{settings.showIntraday && valuationSeries[item.code] && valuationSeries[item.code].length >= 2}}" class="intraday-section">
        <intraday-chart 
          series="{{valuationSeries[item.code]}}" 
          referenceNav="{{item.dwjz}}"
          canvasId="{{item.code}}"
        ></intraday-chart>
      </view>

      <!-- 口粮信息（可展开） -->
      <view wx:if="{{item.showHoldings && item.holdings && item.holdings.length > 0}}" class="holdings-section">
        <view class="holdings-header">
          <text class="holdings-title">前十大口粮</text>
          <text wx:if="{{item.holdingsTotalPercent}}" class="holdings-total">占比{{item.holdingsTotalPercent}}</text>
          <text wx:if="{{item.holdingsConcentrationHint}}" class="holdings-hint">{{item.holdingsConcentrationHint}}</text>
        </view>
        <view class="holdings-table">
          <view class="holdings-thead">
            <text class="col-name">股票简称</text>
            <text class="col-change">增减幅</text>
            <text class="col-weight">口粮占比</text>
          </view>
          <view wx:for="{{item.holdings}}" wx:key="code" wx:for-item="stock" class="holding-item">
            <view class="holding-info">
              <text class="holding-name">{{stock.name}}</text>
              <text class="holding-code">{{stock.code}}</text>
            </view>
            <text class="holding-change {{stock.change > 0 ? 'rise' : stock.change < 0 ? 'fall' : ''}}">
              {{stock.change != null ? (stock.change > 0 ? '+' : '') + stock.change + '%' : '--'}}
            </text>
            <text class="holding-weight">{{stock.weight || '--'}}</text>
          </view>
        </view>
      </view>

      <!-- 展开/收起按钮 -->
      <view 
        wx:if="{{item.holdings && item.holdings.length > 0}}"
        class="expand-btn"
        catchtap="toggleHoldings"
        data-code="{{item.code}}"
      >
        <text>{{item.showHoldings ? '收起' : '展开'}}口粮</text>
        <text class="arrow {{item.showHoldings ? 'up' : 'down'}}">›</text>
      </view>
    </view>

    <view class="list-footer">
      <text class="footer-text">- 已显示全部 -</text>
    </view>
  </scroll-view>
</view>

<!-- 设置弹窗 -->
<view wx:if="{{showSettings}}" class="modal-overlay" bindtap="hideSettingsModal">
  <view class="glass modal-content settings-modal" catchtap="preventClose">
    <view class="modal-header">
      <text class="modal-title">设置</text>
      <view class="close-btn" bindtap="hideSettingsModal">
        <view class="icon-close"></view>
      </view>
    </view>
    
    <view class="setting-item">
      <text class="setting-label">自动刷新</text>
      <switch checked="{{settings.autoRefresh}}" bindchange="toggleAutoRefresh" />
    </view>
    
    <view class="setting-item">
      <text class="setting-label">刷新间隔</text>
      <picker 
        mode="selector" 
        range="{{refreshIntervals}}" 
        range-key="label"
        value="{{refreshIntervalIndex}}"
        bindchange="changeRefreshInterval"
      >
        <text class="setting-value">{{refreshIntervals[refreshIntervalIndex].label}}</text>
      </picker>
    </view>

    <view class="setting-item">
      <text class="setting-label">默认展开口粮</text>
      <switch checked="{{settings.showHoldings}}" bindchange="toggleShowHoldings" />
    </view>

    <view class="setting-item">
      <text class="setting-label">显示分时图</text>
      <switch checked="{{settings.showIntraday}}" bindchange="toggleShowIntraday" />
    </view>
  </view>
</view>
