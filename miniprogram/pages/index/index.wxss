/* pages/index/index.wxss */
.index-container {
  min-height: 100vh;
  padding: 20rpx;
  /* 专业金融蓝渐变背景 */
  background: linear-gradient(180deg, #0052D9 0%, #1677FF 50%, #4096FF 100%);
}

/* 搜索区域 */
.search-section {
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #1677FF 0%, #0052D9 100%);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.4);
}

.search-results {
  margin-top: 20rpx;
  max-height: 500rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
}

.results-list {
  max-height: 500rpx;
}

.result-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-info {
  display: flex;
  flex-direction: column;
}

.result-code {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.result-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.add-icon {
  font-size: 48rpx;
  color: #1677FF;
  font-weight: 300;
}

/* Tab区域 */
.tab-section {
  display: flex;
  margin-bottom: 20rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-weight: 500;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.action-left,
.action-right {
  display: flex;
  gap: 20rpx;
}

.refresh-btn,
.settings-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #fff;
}

.rotating {
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 基金列表 */
.fund-list {
  height: calc(100vh - 400rpx);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 基金卡片 - 纯白卡片设计 */
.fund-card {
  margin-bottom: 20rpx;
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #F0F0F0;
}

.fund-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.fund-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.fund-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.fund-code {
  font-size: 24rpx;
  color: #999999;
  font-family: 'Roboto', 'Helvetica Neue', sans-serif;
}

.fund-actions {
  display: flex;
  gap: 20rpx;
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F5F5;
  font-size: 32rpx;
  color: #666666;
}

.favorite-icon.active {
  background: #FFF3E0;
  color: #FFA726;
}

.delete-icon {
  background: #FFEBEE;
  color: #D32F2F;
  font-size: 40rpx;
}

/* 净值信息 - 专业金融数据展示 */
.fund-values {
  display: flex;
  padding: 24rpx 0;
  border-top: 1rpx solid #E0E0E0;
  border-bottom: 1rpx solid #E0E0E0;
  background: #FAFAFA;
  margin: 0 -30rpx;
  padding: 24rpx 30rpx;
}

.value-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.value-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.value-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 8rpx;
  /* 使用金融专用等宽字体 */
  font-family: 'DIN Alternate', 'Roboto', 'Helvetica Neue', sans-serif;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.5rpx;
}

.value-date {
  font-size: 22rpx;
  color: #CCCCCC;
}

.value-change {
  font-size: 28rpx;
  font-weight: 500;
  font-family: 'DIN Alternate', 'Roboto', 'Helvetica Neue', sans-serif;
  font-variant-numeric: tabular-nums;
}

.value-divider {
  width: 2rpx;
  height: 100rpx;
  background: #E0E0E0;
}

.fund-footer {
  margin-top: 20rpx;
  text-align: center;
}

.update-time {
  font-size: 22rpx;
  color: #CCCCCC;
}

/* 分时图区域 */
.intraday-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #E0E0E0;
  background: #FFFFFF;
}

/* 持仓信息 */
.holdings-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #E0E0E0;
}

.holdings-title {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.holdings-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.holding-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.holding-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.holding-name {
  font-size: 26rpx;
  color: #1A1A1A;
  margin-bottom: 4rpx;
}

.holding-code {
  font-size: 22rpx;
  color: #999999;
  font-family: 'Roboto', sans-serif;
}

.holding-data {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.holding-weight {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
  font-family: 'DIN Alternate', 'Roboto', sans-serif;
  font-variant-numeric: tabular-nums;
}

.holding-change {
  font-size: 24rpx;
  font-weight: 500;
  font-family: 'DIN Alternate', 'Roboto', sans-serif;
  font-variant-numeric: tabular-nums;
}

.expand-btn {
  margin-top: 20rpx;
  padding: 16rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666666;
  border-top: 1rpx solid #E0E0E0;
}

.arrow {
  font-size: 32rpx;
  font-weight: 300;
  transform: rotate(90deg);
  transition: transform 0.3s;
}

.arrow.up {
  transform: rotate(-90deg);
}

.arrow.down {
  transform: rotate(90deg);
}

.list-footer {
  padding: 40rpx 0;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  padding: 40rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.7);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.setting-value {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}
