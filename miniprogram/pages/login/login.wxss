/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: linear-gradient(180deg, #0A0A0A 0%, #141210 50%, #1A1510 100%);
}

.login-box {
  width: 100%;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #D4A84B 0%, #B08930 100%);
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #D4A84B;
  margin-bottom: 12rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.login-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-tips {
  width: 100%;
  margin-bottom: 40rpx;
}

.tips-text {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  margin-bottom: 30rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.65);
}

.tip-icon {
  width: 40rpx;
  height: 40rpx;
  background: rgba(212, 168, 75, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 24rpx;
  color: #D4A84B;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #D4A84B 0%, #B08930 100%);
  color: #0A0A0A;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(212, 168, 75, 0.35);
}

.login-btn::after {
  border: none;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(212, 168, 75, 0.5);
}

.nickname {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.status {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 40rpx;
}

.btn-back {
  width: 100%;
  height: 88rpx;
  background: rgba(212, 168, 75, 0.12);
  color: #D4A84B;
  border: 2rpx solid rgba(212, 168, 75, 0.3);
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-back::after {
  border: none;
}

.login-footer {
  margin-top: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
}

.link {
  color: #D4A84B;
  text-decoration: underline;
}
