/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  /* 专业金融蓝渐变背景 */
  background: linear-gradient(180deg, #0052D9 0%, #1677FF 50%, #4096FF 100%);
}

.login-box {
  width: 100%;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  background: #fff;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-tips {
  width: 100%;
  margin-bottom: 40rpx;
}

.tips-text {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  margin-bottom: 30rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.tip-icon {
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 24rpx;
  color: #fff;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1677FF 0%, #0052D9 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.4);
}

.login-btn::after {
  border: none;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.nickname {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.status {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 40rpx;
}

.btn-back {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #1677FF;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-back::after {
  border: none;
}

.login-footer {
  margin-top: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.link {
  color: #fff;
  text-decoration: underline;
}
