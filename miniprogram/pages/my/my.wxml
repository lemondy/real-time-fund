<!-- pages/my/my.wxml -->
<view class="my-container">
  <!-- 用户信息区域 -->
  <view class="glass user-section">
    <view wx:if="{{hasUserInfo}}" class="user-info-box">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="nickname">{{userInfo.nickName}}</text>
        <text class="user-id">ID: {{openid}}</text>
      </view>
      <!-- 如果是默认用户信息，显示更新按钮 -->
      <button wx:if="{{userInfo.nickName === '微信用户'}}" class="btn-update-info" bindtap="updateUserInfo">
        更新信息
      </button>
    </view>
    <view wx:else class="login-prompt" bindtap="goToLogin">
      <image class="avatar-default" src="/images/user-default.png" mode="aspectFit"></image>
      <view class="login-text">
        <text class="login-title">点击登录</text>
        <text class="login-desc">登录后数据云端同步</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 数据统计 2×2 -->
  <view class="glass stats-section">
    <view class="stats-grid">
      <!-- 养鸡总投入 -->
      <view class="stat-cell">
        <text class="stat-cell-label">养鸡总投入(元)</text>
        <text class="stat-cell-value">{{hasPnlData ? totalCost : '--'}}</text>
      </view>
      <!-- 关注数 -->
      <view class="stat-cell stat-cell-right">
        <text class="stat-cell-label">关注小鸡</text>
        <text class="stat-cell-value gold">{{fundCount}}</text>
      </view>
      <!-- 分隔线 -->
      <view class="stats-row-divider"></view>
      <!-- 今日产蛋 -->
      <view class="stat-cell">
        <text class="stat-cell-label">今日产蛋(元)</text>
        <text class="stat-cell-value {{hasPnlData ? (todayPnl >= 0 ? 'rise' : 'fall') : ''}}">
          {{hasPnlData ? todayPnlStr : '--'}}
        </text>
      </view>
      <!-- 投养回报率 -->
      <view class="stat-cell stat-cell-right">
        <text class="stat-cell-label">投养回报率</text>
        <text class="stat-cell-value {{hasPnlData ? (totalPnl >= 0 ? 'rise' : 'fall') : ''}}">
          {{hasPnlData ? totalPnlRateStr : '--'}}
        </text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="glass menu-section">
    <view class="menu-item" bindtap="handleSync">
      <view class="menu-left">
        <view class="menu-icon icon-sync"></view>
        <text class="menu-text">数据同步</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    
    <view class="menu-item" bindtap="handleClearCache">
      <view class="menu-left">
        <view class="menu-icon icon-trash"></view>
        <text class="menu-text">清除缓存</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    
    <view class="menu-item" bindtap="handleAbout">
      <view class="menu-left">
        <view class="menu-icon icon-info"></view>
        <text class="menu-text">关于我们</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view wx:if="{{hasUserInfo}}" class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">咕咕看板 v{{version}}</text>
  </view>
</view>
