/* pages/my/my.wxss */
.my-container {
  min-height: 100vh;
  padding: 20rpx;
  /* 专业金融蓝渐变背景 */
  background: linear-gradient(180deg, #0052D9 0%, #1677FF 50%, #4096FF 100%);
}

.user-section {
  margin-bottom: 20rpx;
  padding: 40rpx;
}

.user-info-box {
  display: flex;
  align-items: center;
  position: relative;
}

.btn-update-info {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #1677FF;
  font-size: 24rpx;
  border-radius: 20rpx;
  border: none;
}

.btn-update-info::after {
  border: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
  background: rgba(255, 255, 255, 0.2);
}

.user-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.login-prompt {
  display: flex;
  align-items: center;
}

.login-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.login-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
}

.stats-section {
  margin-bottom: 20rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
}

.menu-section {
  margin-bottom: 20rpx;
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #fff;
}

.menu-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 0 40rpx;
}

.logout-section {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: rgba(211, 47, 47, 0.15);
  color: #fff;
  border: 2rpx solid rgba(211, 47, 47, 0.3);
  border-radius: 16rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn::after {
  border: none;
}

.version-info {
  text-align: center;
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.version-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}
